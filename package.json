{
  "name": "devops-ai-skill",
  "version": "1.2.0",
  "description": "Cross-platform DevOps AI Skill Pack — Horus (IaC) + Zeus (GitOps) agents for Claude Code, OpenAI Codex CLI, Google Gemini CLI, and Google Antigravity",
  "keywords": [
    "devops",
    "ai-skills",
    "terraform",
    "helm",
    "kustomize",
    "argocd",
    "claude-code",
    "codex-cli",
    "gemini-cli",
    "antigravity",
    "agent-skills"
  ],
  "homepage": "https://github.com/qwedsazxc78/devops-ai-skill",
  "repository": {
    "type": "git",
    "url": "https://github.com/qwedsazxc78/devops-ai-skill.git"
  },
  "license": "MIT",
  "author": "Awoo Platform Team",
  "packageManager": "pnpm@10.27.0",
  "files": [
    "skills/",
    "prompts/",
    "scripts/",
    "docs/",
    ".claude/agents/",
    ".claude-plugin/",
    ".codex/",
    ".gemini/",
    ".agents/",
    "CLAUDE.md",
    "AGENTS.md",
    "GEMINI.md",
    "VERSION",
    "CHANGELOG.md",
    "README.md"
  ],
  "scripts": {
    "test": "bash tests/test-structure.sh && bash tests/test-setup-scripts.sh",
    "test:structure": "bash tests/test-structure.sh",
    "test:setup": "bash tests/test-setup-scripts.sh",
    "setup": "bash scripts/setup.sh",
    "setup:all": "bash scripts/setup.sh --all",
    "setup:claude": "bash scripts/setup/setup-claude.sh",
    "setup:codex": "bash scripts/setup/setup-codex.sh",
    "setup:gemini": "bash scripts/setup/setup-gemini.sh",
    "setup:antigravity": "bash scripts/setup/setup-antigravity.sh",
    "version:check": "bash scripts/version-check.sh",
    "version:consistency": "bash scripts/version-consistency.sh",
    "version:bump": "bash scripts/version-bump.sh",
    "release": "bash scripts/release.sh",
    "postinstall": "node scripts/postinstall.js 2>/dev/null || true"
  }
}
